---
import DeckLayout from "../components/DeckLayout.astro";

interface DeckModule {
  default: any;
  frontmatter: { title?: string; description?: string; image?: string; [key: string]: any };
}

export async function getStaticPaths() {
  const modules = import.meta.glob<DeckModule>("/src/decks/**/*.deck.mdx", { eager: true });
  return Object.entries(modules)
    // A deck with `published: false` in its frontmatter is dropped from the
    // production build only — no route, so no HTML in dist/ and nothing for
    // Pagefind to index. The dev server still serves it (PROD is false there)
    // so work-in-progress decks stay previewable locally. Absent/true stays
    // published, matching the usual content-collection default; the check is
    // strict `=== false` so only an explicit opt-out hides a deck.
    .filter(([, mod]) => !(import.meta.env.PROD && mod.frontmatter?.published === false))
    .map(([filePath, mod]) => {
      const match = filePath.match(/\/src\/decks\/(.+)\.deck\.mdx$/);
      if (!match) throw new Error(`Unexpected deck path: ${filePath}`);
      const name = match[1];
      const slug = name.endsWith("/slides") ? name.slice(0, -"/slides".length) : name;
      return {
        params: { slug },
        props: { Content: mod.default, frontmatter: mod.frontmatter ?? {} },
      };
    });
}

const { Content, frontmatter } = Astro.props;
---

<DeckLayout
  title={frontmatter.title ?? "Deck"}
  description={frontmatter.description}
  image={frontmatter.image}
>
  <div class="reveal" role="main">
    <div class="slides">
      <Content />
    </div>
  </div>
</DeckLayout>

<script>
  import Reveal from "reveal.js";
  import RevealNotes from "reveal.js/plugin/notes";

  import { keepAwakeInFullscreen } from "../src/keep-awake";
  import { initWhiteboard } from "../src/whiteboard";

  // Drop slides gated behind an `_if:` directive whose query param is absent
  // from the deck URL, before Reveal reads the DOM — so slide indices and
  // `#/` hashes count only the slides that survive. A slide tagged
  // `{/* _if: presenters */}` is hidden unless the URL carries `?presenters`.
  const params = new URLSearchParams(location.search);
  document.querySelectorAll(".slides section[data-deck-if]").forEach((slide) => {
    const cond = slide.getAttribute("data-deck-if");
    if (cond && !params.has(cond)) slide.remove();
  });

  const deck = new Reveal({
    width: 1280,
    height: 720,
    margin: 0,
    hash: true,
    hashOneBasedIndex: true,
    controls: false,
    navigationMode: "linear",
    transition: "none",
    display: "grid",
    center: true,
    viewDistance: 10,
    maxScale: 4,
    // The canvas is fixed at 1280x720, so in print view (?print-pdf) a
    // slide can never legitimately span pages --- scrollHeight overflow is
    // always decorative (glows, full-bleed backgrounds) and would otherwise
    // mint background-only filler pages.
    pdfMaxPagesPerSlide: 1,
    scrollActivationWidth: null,
    plugins: [RevealNotes],
  });
  // Whiteboard registers a Reveal key binding, so wait for the keyboard
  // controller to be ready.
  void deck.initialize().then(() => initWhiteboard(deck));
  keepAwakeInFullscreen();
</script>
