---
import { Font } from "astro:assets";
import { fontVariables } from "virtual:astromotion/fonts";
import { favicon, ogImage } from "virtual:astromotion/head";
import { absoluteUrl, withBase } from "../src/head-urls.ts";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "Slide deck", image } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url);

// A deck's own `image:` frontmatter beats the integration-wide default. With
// neither, the social-card tags are omitted rather than pointed at a file the
// consumer may never have created.
const social = image ?? ogImage;
const socialUrl = social ? absoluteUrl(social, Astro.site, Astro.url, baseUrl) : undefined;
const faviconHref = favicon ? withBase(favicon, baseUrl) : undefined;
---

{fontVariables.map((cssVariable) => <Font cssVariable={cssVariable} preload />)}

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="description" content={description} />
<title>{title}</title>

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl.href} />
<meta property="og:type" content="website" />
{
  socialUrl && (
    <>
      <meta property="og:image" content={socialUrl} />
      <meta property="og:image:width" content="1200" />
      <meta property="og:image:height" content="630" />
    </>
  )
}

<meta name="twitter:card" content={socialUrl ? "summary_large_image" : "summary"} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{socialUrl && <meta name="twitter:image" content={socialUrl} />}

{faviconHref && <link rel="icon" type="image/svg+xml" href={faviconHref} />}
