---
import DeckHead from "./DeckHead.astro";
import "reveal.js/reveal.css";
import "../theme/base.css";
import "../theme/whiteboard.css";
import "virtual:astromotion/theme";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <DeckHead title={title} description={description} image={image} />
  </head>
  <body>
    <slot />
  </body>
</html>
